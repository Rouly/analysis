{
  "name": "sales-replay",
  "version": "0.1.0",
  "description": "单兵销售复盘助手 — 本地实时转写 + 我/客户区分 + 复盘分析",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "backend": "python backend/server.py",
    "build:backend": "pyinstaller backend/server.spec --distpath build/backend --workpath build/tmp -y",
    "dist": "electron-builder --win"
  },
  "author": "Rouly",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.rouly.salesreplay",
    "productName": "销售复盘助手",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "extraResources": [
      {
        "from": "build/backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "artifactName": "${productName}-${version}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
